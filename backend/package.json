{
  "name": "leetcode-ai-mcp-assistant",
  "version": "1.0.0",
  "description": "Production-ready LeetCode AI assistant with MCP Server, REST API, WebSockets, and AI-powered tools",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --runInBand --forceExit",
    "test:unit": "node --experimental-vm-modules node_modules/.bin/jest tests/unit --runInBand --forceExit",
    "test:integration": "node --experimental-vm-modules node_modules/.bin/jest tests/integration --runInBand --forceExit",
    "migrate": "node migrations/run.js",
    "migrate:rollback": "node migrations/rollback.js",
    "lint": "eslint src --ext .js"
  },
  "dependencies": {
    "@google/genai": "^2.11.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.2",
    "express-rate-limit": "^7.5.1",
    "express-validator": "^7.3.2",
    "graphql-request": "^7.4.0",
    "helmet": "^7.2.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.11.0",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.22.0",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^10.0.0",
    "winston": "^3.19.0",
    "ws": "^8.21.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.0.0"
  },
  "jest": {
    "transform": {},
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/server.js"
    ]
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "author": "LeetCode AI MCP Assistant",
  "license": "MIT"
}
