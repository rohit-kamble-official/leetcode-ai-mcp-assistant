# Dependencies — reinstalled fresh inside the container
node_modules/

# Build output — rebuilt inside the container
dist/
build/

# Environment files — never bake secrets into the image
.env
.env.*
!.env.example

# Version control
.git/
.gitignore

# Editor and OS files
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
*.swo

# Logs
*.log
npm-debug.log*

# Test output
coverage/

# Docker files themselves (no need to copy into image)
Dockerfile
docker-compose.yml
.dockerignore

